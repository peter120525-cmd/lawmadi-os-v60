# ═══════════════════════════════════════════════════
# Lawmadi OS v60.0.0 환경변수 설정 예시
# 이 파일을 .env로 복사하여 실제 값을 입력하세요.
# ═══════════════════════════════════════════════════

# === 필수 (Required) ===
GEMINI_KEY=your_gemini_api_key
GEMINI_API_KEY=your_gemini_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
LAWGO_DRF_OC=your_drf_api_key

# === 데이터베이스 (Cloud SQL) ===
CLOUD_SQL_INSTANCE=your_project:region:instance
DB_USER=postgres
DB_PASS=your_db_password
DB_NAME=postgres
DATABASE_URL=postgresql://user:password@/cloudsql/project:region:instance/dbname

# === 선택 (Optional) ===
GEMINI_MODEL=gemini-3-flash-preview
INTERNAL_API_KEY=your_internal_api_key
CORS_EXTRA_ORIGINS=http://localhost:3000
SOFT_MODE=true
DB_DISABLED=false
ENABLE_DB_CACHE=false
SWARM_ENABLED=true
SWARM_MULTI=true
SWARM_MAX_LEADERS=3
DATA_GO_KR_API_KEY=your_data_go_kr_key
PORT=8080

# === 결제 (Paddle) ===
PADDLE_CLIENT_TOKEN=your_paddle_client_token
PADDLE_ENVIRONMENT=sandbox
PREMIUM_KEYS=your_premium_key_here

# === MCP 서버 ===
MCP_API_KEY=your_mcp_api_key

# === 이메일 (SMTP) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_FROM=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# === 운영 설정 ===
DAILY_FREE_LIMIT=2
SESSION_EXPIRY_DAYS=30

# === Zapier 연동 (External API) ===
# 쉼표로 구분하여 여러 키 등록 가능. 미설정 시 /api/v1/* 오픈(인증 비활성).
API_KEYS=your_zapier_api_key_here
