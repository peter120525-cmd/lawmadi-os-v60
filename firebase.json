{
  "hosting": {
    "public": "frontend/public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "/index.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
        ]
      },
      {
        "source": "/index-en.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
        ]
      },
      {
        "source": "/sw.js",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
        ]
      },
      {
        "source": "/manifest.json",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
        ]
      },
      {
        "source": "**/*.@(jpg|jpeg|png|gif|svg|webp|ico|mp4)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=604800, immutable" }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/en",
        "destination": "/index-en.html"
      },
      {
        "source": "/about",
        "destination": "/about.html"
      },
      {
        "source": "/about-en",
        "destination": "/about-en.html"
      },
      {
        "source": "/leaders",
        "destination": "/leaders.html"
      },
      {
        "source": "/leaders-en",
        "destination": "/leaders-en.html"
      },
      {
        "source": "/clevel-en",
        "destination": "/clevel-en.html"
      },
      {
        "source": "/leader",
        "destination": "/leader-profile.html"
      },
      {
        "source": "/api/**",
        "function": "api"
      }
    ]
  }
}
