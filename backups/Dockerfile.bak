FROM python:3.11-slim

# 시스템 의존성 라이브러리가 필요한 경우 여기에 추가
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# 캐싱 효율을 위해 requirements 먼저 복사
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# 나머지 소스 코드 및 설정 파일(config.json, leaders.json) 복사
COPY . .

# Cloud Run은 PORT 환경 변수를 자동으로 주입합니다.
ENV PORT=8080
ENV PYTHONUNBUFFERED=1

# [중요] 파일명이 main.py라면 main:app, app.py라면 app:app으로 설정하세요.
# exec 형식을 사용하여 컨테이너가 OS 신호를 직접 받도록 합니다.
CMD ["sh", "-c", "uvicorn main:app --host 0.0.0.0 --port ${PORT}"]