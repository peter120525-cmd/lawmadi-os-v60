        "profile": "법원행정처 전산정보국장 출신급"
      }
    }
  },
  "security_layer": {
    "anti_leak_policy": {
      "mode": "STRICT",
      "block_on_violation": true
    },
    "safety": {
      "trigger_keywords": [
        "자살",
        "죽고싶다"
      ],
      "crisis_resources": {
        "생명의 전화": "1577-0199",
        "경찰": "112"
      }
    }
  },
  "network_security": {
    "circuit_breaker": {
      "per_provider": {
        "LAW_GO_KR_DRF": {
          "failure_threshold": 3,
          "reset_timeout_ms": 30000
        }
      }
    }
  },
  "data_sync_connectors": {
    "request_timeout_ms": 10000,
    "api_failure_policy": "FAIL_CLOSED",
    "drf_endpoints": {
      "lawSearch": "https://www.law.go.kr/DRF/lawSearch.do",
      "lawService": "https://www.law.go.kr/DRF/lawService.do",
      "precSearch": "https://www.law.go.kr/DRF/lawSearch.do",
      "precService": "https://www.law.go.kr/DRF/lawService.do"
    }
  },
  "drf": {
    "base_url": "https://apis.data.go.kr/1170000/LawService",
    "api_key_env": "DATA_GO_KR_API_KEY",
    "default_format": "XML",
    "endpoints": {
      "lawSearch": "lawSearch.do",
      "lawList": "lawSearchList.do"
    }
  },
  "dual_ssot": {
    "primary": {
      "type": "LAW_GO_KR",
      "base_url": "https://www.law.go.kr/DRF"
    },
    "fallback": {
      "type": "OPEN_DATA_GO_KR",
      "base_url": "https://apis.data.go.kr/1170000/LawService"
    }
  },
  "ssot_registry": {
    "SSOT_01": {
      "name": "현행법령",
