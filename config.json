  "data_sync_connectors": {
    "drf_endpoints": {
      "law_search": "https://www.law.go.kr/DRF/lawSearch.do",
      "law_service": "https://www.law.go.kr/DRF/lawService.do"
    },
    "request_timeout_ms": 8000,
    "cache_ttl_days": 30,
    "cache_max_size_mb": 512,
    "rate_limits": {
      "LAW_GO_KR_DRF": {
        "requests_per_minute": 120,
        "concurrent_max": 7
      },
      "NOMINATIM": {
        "requests_per_second": 1,
        "burst_allowance": 0
      }
    },
    "api_failure_policy": {
      "on_down": "FAIL_CLOSED",
      "fallback_mode": "VERIFIED_CACHE_ONLY",
      "max_consecutive_failures": 5,
      "retry_interval_sec": 60,
      "max_retries": 5
    }
  },
  "temporal_engine_settings": {
    "default_timezone": "Asia/Seoul",
    "strict_addenda_parsing": true,
    "historical_data_limit_year": 1948,
    "date_internal_standard": "YYYYMMDD",
    "date_accepted_inputs": [
      "STRING_YYYYMMDD",
      "INT_YYYYMMDD",
      "STRING_WITH_DOTS"
    ],
    "temporal_modes": {
      "SUBSTANTIVE_RIGHTS": "ACT_TIME",
      "PROCEDURE_EXECUTION": "JUDGMENT_TIME",
      "UNKNOWN": "ASK_USER_CONFIRMATION"
    },
    "sunset_clause_detection": {
      "enabled": true,
      "sources": [
        "DRF_METADATA_EXPIRY_DATE",
        "DRF_METADATA_VALID_TO"
      ]
    }
  },
  "performance_budget": {
    "hard_latency_limit_ms": 8000,
    "soft_latency_target_ms": 3000,
    "memory_usage_warning_threshold": 75.0,
    "max_concurrency_limit": 100
  },
  "logging_strategy": {
    "log_level": "INFO",
    "save_to_file": true,
    "anonymize_user_data": true,
    "pii_sensitive_fields": [
      "user_name",
      "phone_number",
      "resident_registration_number",
      "address",
      "email",
      "ip_address",
      "legal_case_details"
