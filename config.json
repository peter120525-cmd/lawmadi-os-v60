  "OUTPUT_FORMAT_POLICY": {
    "LEGAL_SECTION": {
      "required": true,
      "source_must_be": "DRF",
      "header": "📚 법률 근거",
      "disclaimer": "> ※ 본 내용은 대한민국 법령/판례/공식 데이터에 기초하여 정리한 참고 의견이며, 구체 사안에 대한 유권해석/법적 효력을 보장하지 않습니다.",
      "on_unavailable": "📌 현재 DRF(국가법령정보) 연결/검증이 불가하여 **법률 근거 섹션을 제공할 수 없습니다.**"
    },
    "REFERENCE_SECTION": {
      "required": false,
      "header": "🔍 참고 정보",
      "disclaimer": "> ※ [참고] 아래 정보는 외부 공개 API(Open Data)를 참조한 내용으로, 법적 근거로 직접 활용할 수 없습니다.",
      "segregation_enforced": true,
      "visual_separator": "---",
      "timeline_v2_placement": {
        "enabled": true,
        "header": "🕐 시간축 분석 (Timeline Analysis)"
      }
    }
  },
  "SWARM_ENGINE": {
    "version": "2.1",
    "leader_registry": {
      "L01": {
        "name": "휘율",
